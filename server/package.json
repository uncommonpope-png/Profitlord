{
  "name": "profitlord-server",
  "version": "1.0.0",
  "description": "Profitlord Command Center backend for Render",
  "main": "index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node index.js"
  },
  "dependencies": {
    "redis": "^5.11.0"
  },
  "_envVars": {
    "GH_TOKEN": "GitHub personal access token with repo write access",
    "GH_OWNER": "Repository owner (e.g. uncommonpope-png)",
    "GH_REPO": "Repository name (e.g. Profitlord)",
    "GH_BRANCH": "Branch to commit state updates to (default: main)",
    "GH_CLIENT_ID": "GitHub OAuth App client ID",
    "GH_CLIENT_SECRET": "GitHub OAuth App client secret",
    "REDIS_URL": "Redis connection URL (e.g. redis://host:6379)",
    "BOT_TOKEN": "Telegram bot token from @BotFather",
    "CHAT_ID": "Telegram chat/user ID to deliver messages to",
    "HEARTBEAT_INTERVAL_MINS": "Heartbeat cadence in minutes (default: 30)",
    "PORT": "Listening port (default: 3000)"
  }
}
